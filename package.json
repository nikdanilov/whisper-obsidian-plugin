{
	"name": "whisper",
	"version": "1.5.6",
	"description": "Speech-to-text in Obsidian using OpenAI Whisper",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"release": "release-it"
	},
	"keywords": [],
	"author": "Nik Danilov",
	"license": "MIT",
	"devDependencies": {
		"@commitlint/cli": "^19.0.0",
		"@commitlint/config-conventional": "^19.0.0",
		"@release-it/conventional-changelog": "^8.0.0",
		"@types/node": "^20.0.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"builtin-modules": "^3.3.0",
		"dotenv": "^16.4.0",
		"esbuild": "^0.21.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"obsidian": "^1.7.2",
		"prettier": "^3.0.0",
		"release-it": "^17.0.0",
		"tslib": "^2.6.0",
		"typescript": "^5.5.0"
	},
	"dependencies": {},
	"release-it": {
		"hooks": {
			"before:release": "npm run build",
			"after:bump": "node verify-and-update.mjs",
			"pre-commit": "lint-staged"
		},
		"lint-staged": {
			"*": "prettier --write"
		},
		"git": {
			"commitMessage": "chore: release v${version}",
			"github": {
				"release": true,
				"assets": [
					"main.js",
					"manifest.json",
					"styles.css"
				]
			}
		},
		"npm": {
			"publish": false
		},
		"plugins": {
			"@release-it/conventional-changelog": {
				"infile": "CHANGELOG.md",
				"preset": {
					"name": "conventionalcommits",
					"types": [
						{
							"type": "feat",
							"section": "Features"
						},
						{
							"type": "fix",
							"section": "Bug Fixes"
						}
					]
				}
			}
		}
	}
}
